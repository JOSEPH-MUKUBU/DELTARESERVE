              "mode": "graphql",
              "graphql": {
                "query": "mutation {\n  createBooking(input: {\n    room_id: \"room-002\"\n    user_id: \"user-gql-99\"\n    user_name: \"Client API\"\n    user_email: \"client@api.com\"\n    date_debut: \"2026-09-01\"\n    date_fin: \"2026-09-02\"\n    motif: \"Test GraphQL Postman\"\n  }) {\n    id\n    statut\n    montant\n  }\n}",
                "variables": ""
