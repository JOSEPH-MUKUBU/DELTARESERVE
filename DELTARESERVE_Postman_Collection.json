    {
      "name": "2. GraphQL",
      "item": [
        {
          "name": "Query: Lister les Salles",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "query {\n  rooms {\n    id\n    nom\n    type\n    capacite\n    prix\n    localisation\n    disponible\n  }\n}",
                "variables": ""
              }
            },
            "url": {
              "raw": "http://localhost:3000/graphql",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["graphql"]
            }
          }
        },
        {
          "name": "Query: Liste des Réservations",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "query {\n  allBookings {\n    id\n    user_name\n    date_debut\n    statut\n    montant\n    room {\n      nom\n      localisation\n    }\n  }\n}",
                "variables": ""
              }
            },
            "url": {
              "raw": "http://localhost:3000/graphql",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["graphql"]
            }
